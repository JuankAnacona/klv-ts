{
  "name": "klv-ts",
  "version": "0.1.1",
  "description": "Generic SMPTE 336M KLV parser for JavaScript and TypeScript",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "klv",
    "misb",
    "mpegts",
    "smpte",
    "metadata",
    "video",
    "uas"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JuankAnacona/klv-ts.git"
  },
  "dependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  },
  "devDependencies": {
    "typescript": "5.9.2"
  }
}
